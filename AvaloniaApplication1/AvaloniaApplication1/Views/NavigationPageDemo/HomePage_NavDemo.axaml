<ContentPage x:Class="AvaloniaApplication1.Views.HomePage_NavDemo"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaApplication1.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:HomePageViewModel_NavDemo"
             Header="首页"
             mc:Ignorable="d">
  <Design.DataContext>
    <vm:HomePageViewModel_NavDemo />
  </Design.DataContext>
  <StackPanel Margin="30" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
    <TextBlock FontSize="24" Text="MVVM 导航演示" />

    <Button Width="200" Height="40" Command="{Binding GoToDetailCommand}" Content="前往详情页" />

    <Button Width="200" Height="40" Command="{Binding GoToSettingsCommand}" Content="前往设置页(带参数)" />
  </StackPanel>
</ContentPage>
