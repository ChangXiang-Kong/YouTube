<u:UrsaWindow x:Class="AvaloniaApplication1.Views.MainWindow"
              xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:data="using:AvaloniaApplication1.Data"
              xmlns:iri="https://irihi.tech/shared"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:u="https://irihi.tech/ursa"
              xmlns:views="using:AvaloniaApplication1.Views"
              xmlns:vm="using:AvaloniaApplication1.ViewModels"
              Title="{x:Static data:ResourceToken.AppName}"
              Width="1400"
              Height="800"
              MinWidth="1010"
              MinHeight="600"
              d:DesignHeight="800"
              d:DesignWidth="1400"
              x:CompileBindings="True"
              x:DataType="vm:MainViewModel"
              ExtendClientAreaToDecorationsHint="True"
              Icon="/Assets/avalonia-logo.ico"
              IsFullScreenButtonVisible="{OnPlatform {x:True},
                                                     macOS={x:False}}"
              IsManagedResizerVisible="{OnPlatform {x:False},
                                                   Linux={x:True}}"
              IsTitleBarVisible="True"
              ShowInTaskbar="True"
              WindowStartupLocation="CenterScreen"
              WindowState="Normal"
              mc:Ignorable="d">
  <u:UrsaWindow.LeftContent>
    <views:TitleBarLeftContent />
  </u:UrsaWindow.LeftContent>
  <u:UrsaWindow.RightContent>
    <views:TitleBarRightContent />
  </u:UrsaWindow.RightContent>
  <u:UrsaWindow.Styles>
    <!--  This style is created to demonstrate Dialog StyleClass feature. This style is applied to dialogs in MainWindow OverlayDialogHost  -->
    <Style Selector="u|StandardDialogControl.Custom">
      <Style Selector="^ /template/ Button#PART_OKButton">
        <Setter Property="Content" Value="CUSTOM" />
        <Setter Property="iri:ClassHelper.Classes" Value="Warning" />
      </Style>
    </Style>
  </u:UrsaWindow.Styles>
  <Design.DataContext>
    <!--
      This only sets the DataContext for the previewer in an IDE,
      to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
    -->
    <vm:MainViewModel />
  </Design.DataContext>

  <views:MainView Margin="0,32,0,0" />
  <!--
    以下两种不生效
    WindowDecorationMargin 是 Avalonia 原生窗口 的属性，用于：
    · 系统标题栏高度
    · 窗口缩放边距
    但 UrsaWindow 是自定义窗口，它完全重写了标题栏，不会给 WindowDecorationMargin 赋值 → 永远是 0
    Ursa 窗口的标题栏高度是 固定 32px
  -->
  <!-- <views:MainView Margin="{Binding $parent[Window].WindowDecorationMargin}" /> -->
  <!-- <views:MainView Margin="{Binding $parent[u:UrsaWindow].WindowDecorationMargin}" /> -->

  <!-- 导航根容器_NavDemo
      需要在 MainWindow.axaml.cs 构造函数中添加如下内容
      public MainWindow()
      {
          InitializeComponent();
          // NavDemo
          // 初始化导航服务
          App.NavigationService?.Initialize(MainNav);
          // 设置首页
          App.NavigationService?.PushAsync<HomePage_NavDemo, HomePageViewModel_NavDemo>();
      }
  -->
  <!-- <NavigationPage x:Name="MainNav" BackButtonContent="test" Header="test" Icon="fds" /> -->
</u:UrsaWindow>