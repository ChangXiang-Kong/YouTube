<UserControl x:Class="AvaloniaApplication1.Views.MainView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cvt="using:AvaloniaApplication1.Controls.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:data="using:AvaloniaApplication1.Data"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:views="using:AvaloniaApplication1.Views"
             xmlns:vm="using:AvaloniaApplication1.ViewModels"
             d:DesignHeight="800"
             d:DesignWidth="1400"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d">
  <!--  xmlns:views="clr-namespace:Semi.Avalonia.Demo.Views"  -->
  <Design.DataContext>
    <!--
      This only sets the DataContext for the previewer in an IDE,
      to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
    -->
    <vm:MainViewModel />
  </Design.DataContext>
  <UserControl.Resources>
    <cvt:IconNameToPathConverter x:Key="IconConverter" />
  </UserControl.Resources>

  <Grid RowDefinitions="50, Auto, Auto, *, 32">
    <!--  Select Project  -->
    <!--  提示：在设置 SplitView 的 Width 时，需要与下面的 u:NavMenu 的 ExpandWidth 一起修改  -->
    <SplitView Name="SplitView_SelectProject" Grid.Row="0" Grid.RowSpan="5"
               Width="500" Margin="0,0,0,0" HorizontalAlignment="Left"
               CompactPaneLength="0" DisplayMode="CompactOverlay" IsPaneOpen="False"
               OpenPaneLength="400" PanePlacement="Top" UseLightDismissOverlayMode="False"
               ZIndex="99">
      <SplitView.Pane>
        <Grid Margin="0,0,0,15" HorizontalAlignment="Center" RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0">
            <!-- <ToggleSwitch Name="collapse" OffContent="Expand" OnContent="Collapse" /> -->
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="当前选择：" />
              <TextBlock FontSize="15" FontWeight="Bold" Text="{Binding SelectedMenuItem.Header}" />
            </StackPanel>
          </StackPanel>
          <Border Grid.Row="1" Grid.Column="0" Padding="0" Theme="{DynamicResource CardBorder}">
            <u:NavMenu Name="menu" Classes="enable_animation" ExpandWidth="460"
                       HeaderBinding="{Binding Header}"
                       IconBinding="{Binding IconIndex}"
                       ItemsSource="{Binding MenuItems}"
                       SelectedItem="{Binding SelectedMenuItem}"
                       SubMenuBinding="{Binding Children}">
              <!--  IsHorizontalCollapsed="{Binding #collapse.IsChecked, Mode=OneWay}"  -->
              <u:NavMenu.Styles>
                <Style x:DataType="vm:MenuItem" Selector="u|NavMenuItem">
                  <Setter Property="IsSeparator" Value="{Binding IsSeparator}" />
                </Style>
              </u:NavMenu.Styles>
              <u:NavMenu.Header>
                <Grid HorizontalAlignment="Center" ColumnDefinitions="Auto, Auto">
                  <Panel Margin="4,10" VerticalAlignment="Center" u:NavMenu.CanToggle="True"
                         Background="Transparent" DockPanel.Dock="Left">
                    <iri:IrihiLogo Width="32" Fill="{DynamicResource SemiGrey7}" />
                  </Panel>
                  <TextBlock Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"
                             Classes="H5"
                             IsVisible="{Binding !#menu.IsHorizontalCollapsed}"
                             Text="{x:Static data:ResourceToken.CompanyName}"
                             Theme="{DynamicResource TitleTextBlock}" />
                </Grid>
              </u:NavMenu.Header>
              <u:NavMenu.IconTemplate>
                <DataTemplate DataType="{x:Type x:Int32}">
                  <u:TwoTonePathIcon Width="16" Height="16" Margin="5,0,0,0"
                                     ActiveForeground="{DynamicResource SemiBlue5}"
                                     ActiveStrokeBrush="{DynamicResource SemiBlue5}"
                                     Data="{Binding Converter={StaticResource IconConverter}}"
                                     Foreground="{DynamicResource SemiGrey5}"
                                     IsActive="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=u:NavMenuItem}, Path=IsHighlighted, Mode=TwoWay}"
                                     StrokeBrush="{DynamicResource SemiGrey5}" />
                </DataTemplate>
              </u:NavMenu.IconTemplate>
            </u:NavMenu>
          </Border>
        </Grid>
      </SplitView.Pane>
    </SplitView>

    <!--  Select System  -->
    <SplitView Name="SplitView_SelectSystem" Grid.Row="0" Grid.RowSpan="5"
               CompactPaneLength="0" DisplayMode="CompactOverlay" IsPaneOpen="False"
               OpenPaneLength="400" PanePlacement="Top" UseLightDismissOverlayMode="True"
               ZIndex="99">
      <SplitView.Pane>
        <Grid Margin="20" RowDefinitions="Auto,*">
          <ListBox Grid.Row="1">
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
            <ListBoxItem>ListBoxItem</ListBoxItem>
          </ListBox>
        </Grid>
      </SplitView.Pane>
    </SplitView>

    <!--  Header  -->
    <ThemeVariantScope Grid.Row="0" RequestedThemeVariant="Dark">
      <Grid>
        <Image Source="/Assets/header-bg.png" Stretch="UniformToFill" />
        <DockPanel LastChildFill="False">
          <!--  Left Contents  -->
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
            <TextBlock Margin="5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="这是Logo大图片~~~~~~" />
            <!--  Project Name  -->
            <Button VerticalAlignment="Stretch" Click="Button_SelectProjectClick" Content="电控-晴隆碧痕"
                    FontSize="16" FontWeight="Bold" Foreground="White"
                    Theme="{DynamicResource BorderlessButton}" />
            <!--  System Name  -->
            <Button VerticalAlignment="Stretch" Click="Button_SelectSystemClick" Content="工作台"
                    FontSize="16" FontWeight="Bold" Foreground="White"
                    Theme="{DynamicResource BorderlessButton}" />

            <!--  Menu  -->
            <Menu>
              <MenuItem Padding="10,0" Header="Steam">
                <MenuItem Header="Child 1">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource SemiIconSync}" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Menu Item with _Icon">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource SemiIconAbsoluteStroked}" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="设置">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource SemiIconSetting}" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="退出">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource SemiIconExit}" />
                  </MenuItem.Icon>
                </MenuItem>
              </MenuItem>

              <MenuItem Padding="10,0" Header="Menu2">
                <MenuItem Header="Child 1" />
                <Separator />
                <MenuItem Header="Menu Item with _Icon">
                  <MenuItem.Icon>
                    <TextBlock>😊</TextBlock>
                  </MenuItem.Icon>
                </MenuItem>
              </MenuItem>

              <MenuItem Padding="10,0" Header="Menu3">
                <MenuItem Header="Child 1" />
                <Separator />
                <MenuItem Header="Menu Item with _Icon">
                  <MenuItem.Icon>
                    <TextBlock>😊</TextBlock>
                  </MenuItem.Icon>
                </MenuItem>
              </MenuItem>
            </Menu>
            <Button Margin="5"
                    Command="{Binding GoToPageCommand}"
                    CommandParameter="{x:Static data:ApplicationPageName.StylePreview}"
                    Content="StylePreview"
                    Theme="{DynamicResource SolidButton}" />
            <Button Margin="5"
                    Command="{Binding GoToPageCommand}"
                    CommandParameter="{x:Static data:ApplicationPageName.Settings}"
                    Content="Settings"
                    Theme="{DynamicResource SolidButton}" />
            <Button Margin="5" Click="Button_TestButtonClick" Content="NewSystemNotification" Theme="{DynamicResource SolidButton}" />
          </StackPanel>

          <!--  Right Buttons  -->
          <StackPanel Margin="10,0" DockPanel.Dock="Right" Orientation="Horizontal" Spacing="7">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="这是一些按钮" />
          </StackPanel>
        </DockPanel>
      </Grid>
    </ThemeVariantScope>

    <!--  Notification Area  -->
    <StackPanel Name="StackPanel_NotificationArea" Grid.Row="1" VerticalAlignment="Center">
      <!--  样式示例  -->
      <!--<DockPanel Background="{DynamicResource SemiGreen2}">
        <u:IconButton HorizontalAlignment="Right" VerticalAlignment="Stretch" Classes="Tertiary"
                      DockPanel.Dock="Right"
                      Icon="{DynamicResource SemiIconClose}"
                      Theme="{StaticResource BorderlessIconButton}" />
        <StackPanel Margin="5,0" Orientation="Horizontal" Spacing="10">
          <TextBlock VerticalAlignment="Center" Text="通知" />
          <Button Height="24" MinHeight="20" Classes="Primary"
                  Content="Yes" FontWeight="Normal"
                  Theme="{StaticResource SolidButton}" />
          <Button Height="24" MinHeight="20" Classes="Warning"
                  Content="No" FontWeight="Normal"
                  Theme="{StaticResource SolidButton}" />
        </StackPanel>
      </DockPanel>-->
    </StackPanel>

    <!--  TabControl Area  -->
    <StackPanel Grid.Row="2" Margin="2,0">
      <Border Margin="0" Padding="0" Background="Transparent" Theme="{StaticResource CardBorder}">
        <!--  TabControl Theme 可选项：LineTabControl、CardTabControl、ButtonTabControl，也可默认无 Theme 属性  -->
        <TabControl TabStripPlacement="Top" Theme="{StaticResource ButtonTabControl}">
          <TabItem Header="Tab 1" Icon="{DynamicResource SemiIconFile}" />
          <TabItem Header="Tab 2" />
          <TabItem Header="Tab 3" />
          <TabItem Header="中文中文" />
          <TabItem Header="Tab 4" IsEnabled="False" />
          <TabItem Header="Tab 1" />
          <TabItem Header="Tab 2" />
          <TabItem Header="Tab 3" />
          <TabItem Header="中文中文" />
          <TabItem Header="Tab 4" IsEnabled="False" />
          <TabItem Header="Tab 1" />
          <TabItem Header="Tab 2" />
          <TabItem Header="Tab 3" />
          <TabItem Header="中文中文" />
          <TabItem Header="Tab 4" IsEnabled="False" />
          <TabItem Header="Tab 1" />
          <TabItem Header="Tab 2" />
          <TabItem Header="Tab 3" />
          <TabItem Header="中文中文" />
          <TabItem Header="Tab 4" IsEnabled="False" />
          <TabItem Header="Tab 1" />
          <TabItem Header="Tab 2" />
          <TabItem Header="Tab 3" />
          <TabItem Header="中文中文" />
          <TabItem Header="Tab 4" IsEnabled="False" />
          <TabItem Header="Tab 1" />
          <TabItem Header="Tab 2" />
          <TabItem Header="Tab 3" />
          <TabItem Header="中文中文" />
          <TabItem Header="Tab 4" IsEnabled="False" />
        </TabControl>
      </Border>
      <!-- <Border Background="Transparent" Theme="{StaticResource CardBorder}"> -->
      <!--   <TabControl ItemsSource="{Binding Items}" Theme="{StaticResource CardTabControl}" /> -->
      <!-- </Border> -->
    </StackPanel>

    <Grid Grid.Row="3" Grid.ColumnDefinitions="Auto, *, Auto">
      <!--  Content Body  -->
      <ScrollViewer Grid.Column="1" Margin="2" AllowAutoHide="False">
        <ContentControl Content="{Binding CurrentPage}" />
      </ScrollViewer>

      <!--  Left Bar  -->
      <Border Grid.Column="0" BorderBrush="{DynamicResource TabItemLinePipePointeroverBorderBrush}" BorderThickness="0,0,1,0" IsVisible="True">
        <StackPanel Name="StackPanel_LeftBar" VerticalAlignment="Top">
          <u:IconButton Width="32" Height="32" Classes="Tertiary"
                        Icon="{DynamicResource SemiIconChevronUp}"
                        Theme="{StaticResource BorderlessIconButton}"
                        ToolTip.Placement="Right" ToolTip.Tip="Explore" />
          <u:IconButton Width="30" Height="32" Classes="Tertiary"
                        Icon="{DynamicResource SemiIconChevronUp}"
                        Theme="{StaticResource BorderlessIconButton}"
                        ToolTip.Placement="Right" ToolTip.Tip="Explore" />
          <u:IconButton Width="32" Height="32" Classes="Tertiary"
                        Icon="{DynamicResource SemiIconMore}"
                        Theme="{StaticResource BorderlessIconButton}"
                        ToolTip.Placement="Right" ToolTip.Tip="Explore" />
        </StackPanel>
      </Border>
      <!--  Right Bar  -->
      <Border Grid.Column="2" BorderBrush="{DynamicResource TabItemLinePipePointeroverBorderBrush}" BorderThickness="1,0,0,0">
        <StackPanel Name="StackPanel_RightBar" VerticalAlignment="Top">
          <u:IconButton Width="32" Height="32" Classes="Tertiary"
                        Icon="{DynamicResource SemiIconChevronUp}"
                        Theme="{StaticResource BorderlessIconButton}" />
          <u:IconButton Width="32" Height="32" Classes="Tertiary"
                        Icon="{DynamicResource SemiIconChevronUp}"
                        Theme="{StaticResource BorderlessIconButton}" />
          <u:IconButton Width="32" Height="32" Classes="Tertiary"
                        Icon="{DynamicResource SemiIconChevronUp}"
                        Theme="{StaticResource BorderlessIconButton}" />
        </StackPanel>
      </Border>
    </Grid>

    <!--  Footer  -->
    <Grid Grid.Row="4" Margin="5,0">
      <u:IconButton Name="IconButton_LeftBarToggle" Height="30" Margin="18,-50,0,0"
                    HorizontalAlignment="Left" Classes="Tertiary" Click="IconButton_LeftBarToggleClick"
                    Icon="{DynamicResource SemiIconChevronLeft}"
                    Theme="{StaticResource BorderlessIconButton}"
                    ToolTip.Tip="显示/隐藏侧边栏" />
      <u:IconButton Name="IconButton_RightBarToggle" Height="30" Margin="0,-50,18,0"
                    HorizontalAlignment="Right" Classes="Tertiary" Click="IconButton_RightBarToggleClick"
                    Icon="{DynamicResource SemiIconChevronRight}"
                    Theme="{StaticResource BorderlessIconButton}"
                    ToolTip.Tip="显示/隐藏侧边栏" />
      <u:IconButton Name="IconButton_BottomBarToggle" Height="30" Margin="55,-40,0,0"
                    HorizontalAlignment="Left" Classes="Tertiary" Click="IconButton_BottomBarToggleClick"
                    Icon="{DynamicResource SemiIconChevronDown}"
                    Theme="{StaticResource BorderlessIconButton}"
                    ToolTip.Tip="显示/隐藏侧边栏" />

      <Grid Name="Grid_BottomBar">
        <Border BorderBrush="{DynamicResource TabItemLinePipePointeroverBorderBrush}" BorderThickness="0,1,0,0" />
        <!--  Left Area  -->
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Spacing="5" />

        <!--  Right Area  -->
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="5">
          <!--  View Logs  -->
          <u:Badge Margin="0,10,6,0" Classes="Primary" CornerPosition="TopRight"
                   Dot="True"
                   IsVisible="{Binding AppSettings.DisplayViewLogButton}">
            <u:IconButton Margin="0,-10,-6,0" VerticalAlignment="Stretch" Classes="Tertiary"
                          Icon="{DynamicResource SemiIconFile}"
                          Theme="{StaticResource BorderlessIconButton}"
                          ToolTip.Placement="Top" ToolTip.Tip="查看日志" />
          </u:Badge>
          <u:Badge Margin="0,10,8,0" Classes="Primary" CornerPosition="TopRight"
                   Dot="True"
                   IsVisible="{Binding AppSettings.DisplayViewLogButton}">
            <u:IconButton Margin="0,-10,-8,0" VerticalAlignment="Stretch" Classes="Tertiary"
                          Icon="{DynamicResource SemiIconFile}"
                          Theme="{StaticResource BorderlessIconButton}"
                          ToolTip.Placement="Top" ToolTip.Tip="查看日志">
              <TextBlock Margin="-5,0,0,0" VerticalAlignment="Center" Text="查看日志" />
            </u:IconButton>
          </u:Badge>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</UserControl>