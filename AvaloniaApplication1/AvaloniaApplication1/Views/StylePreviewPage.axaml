<UserControl x:Class="AvaloniaApplication1.Views.StylePreviewPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cvt="using:AvaloniaApplication1.Controls.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:AvaloniaApplication1.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="1200"
             x:DataType="vm:StylePreviewPageViewModel"
             mc:Ignorable="d">
  <Design.DataContext>
    <!--
      This only sets the DataContext for the previewer in an IDE,
      to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
    -->
    <vm:StylePreviewPageViewModel />
  </Design.DataContext>
  <UserControl.Resources>
    <cvt:IconNameToPathConverter x:Key="IconConverter" />
  </UserControl.Resources>

  <Grid>
    <TabControl Name="TabControl_Main" SelectedIndex="2" TabStripPlacement="Left" Theme="{DynamicResource ScrollButtonTabControl}">
      <TabControl.Styles>
        <Style Selector=".Dismiss /template/ ScrollViewer#PART_ScrollViewer">
          <Setter Property="IsVisible" Value="False" />
        </Style>
      </TabControl.Styles>
      <TabControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel />
        </ItemsPanelTemplate>
      </TabControl.ItemsPanel>

      <TabItem MinWidth="120" Header="Test">
        <Grid>
          <Border />
        </Grid>
      </TabItem>

      <TabItem MinWidth="100" Header="Button">
        <StackPanel Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Vertical" Spacing="20">
          <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"
                       Foreground="Black"
                       Text="{Binding Greeting}" />
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"
                       Foreground="Gray"
                       Text="{Binding Greeting}" />
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"
                       Foreground="DarkGray"
                       Text="{Binding Greeting}" />
          </StackPanel>

          <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="5">
            <!--  Icon-Only  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource IconOnlyBackground}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrush}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForeground}">
                <PathIcon Width="15" Data="{StaticResource SemiIconArrowLeft}" />
              </Button>
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource IconOnlyBackgroundOutline}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForegroundOutline}">
                <PathIcon Width="15" Data="{StaticResource SemiIconRefresh2}" />
              </Button>
            </StackPanel>
            <!--  Icon-Only Outline  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource DefaultBackground}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrush}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForeground}">
                <PathIcon Width="15" Data="{StaticResource SemiIconArrowRight}" />
              </Button>
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource IconOnlyBackgroundOutline}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForegroundOutline}">
                <PathIcon Width="15" Data="{StaticResource SemiIconHomeStroked}" />
              </Button>
            </StackPanel>
            <!--  Tertiary  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DefaultBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Default"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DefaultForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DefaultBackgroundOutline}"
                      BorderBrush="{DynamicResource DefaultBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DefaultForegroundOutline}" />
            </StackPanel>
            <!--  Primary  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource PrimaryBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Primary"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource PrimaryForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource PrimaryBackgroundOutline}"
                      BorderBrush="{DynamicResource PrimaryBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource PrimaryForegroundOutline}" />
            </StackPanel>
            <!--  Info  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource InfoBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Info"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource InfoForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource InfoBackgroundOutline}"
                      BorderBrush="{DynamicResource InfoBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource InfoForegroundOutline}" />
            </StackPanel>
            <!--  Success  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource SuccessBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Success"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource SuccessForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource SuccessBackgroundOutline}"
                      BorderBrush="{DynamicResource SuccessBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource SuccessForegroundOutline}" />
            </StackPanel>
            <!--  Warning  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource WarningBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Warning"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource WarningForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource WarningBackgroundOutline}"
                      BorderBrush="{DynamicResource WarningBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource WarningForegroundOutline}" />
            </StackPanel>
            <!--  Danger  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DangerBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Danger"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DangerForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DangerBackgroundOutline}"
                      BorderBrush="{DynamicResource DangerBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DangerForegroundOutline}" />
            </StackPanel>
          </StackPanel>

          <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="5">
            <!--  Icon-Only  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource IconOnlyBackground}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrush}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForeground}">
                <PathIcon Width="15" Data="{StaticResource SemiIconArrowLeft}" />
              </Button>
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource IconOnlyBackgroundOutline}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForegroundOutline}">
                <PathIcon Width="15" Data="{StaticResource SemiIconRefresh2}" />
              </Button>
            </StackPanel>
            <!--  Icon-Only Outline  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource DefaultBackground}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrush}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForeground}">
                <PathIcon Width="15" Data="{StaticResource SemiIconArrowRight}" />
              </Button>
              <Button HorizontalContentAlignment="Center"
                      Background="{DynamicResource IconOnlyBackgroundOutline}"
                      BorderBrush="{DynamicResource IconOnlyBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource IconOnlyForegroundOutline}">
                <PathIcon Width="15" Data="{StaticResource SemiIconHomeStroked}" />
              </Button>
            </StackPanel>
            <!--  Tertiary  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center" Classes="Tertiary"
                      Content="Tertiary"
                      Theme="{DynamicResource SolidButton}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DefaultBackground}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Default"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DefaultForeground}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DefaultBackgroundOutline}"
                      BorderBrush="{DynamicResource DefaultBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DefaultForegroundOutline}" />
            </StackPanel>
            <!--  Primary  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center" Classes="Primary"
                      Content="Primary"
                      Theme="{DynamicResource SolidButton}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource PrimaryBackgroundOutline}"
                      BorderBrush="{DynamicResource PrimaryBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource PrimaryForegroundOutline}" />
            </StackPanel>
            <!--  Info  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center" Classes="Secondary"
                      Content="Secondary"
                      Theme="{DynamicResource SolidButton}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource InfoBackgroundOutline}"
                      BorderBrush="{DynamicResource InfoBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource InfoForegroundOutline}" />
            </StackPanel>
            <!--  Success  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center" Classes="Success"
                      Content="Success"
                      Theme="{DynamicResource SolidButton}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource SuccessBackgroundOutline}"
                      BorderBrush="{DynamicResource SuccessBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource SuccessForegroundOutline}" />
            </StackPanel>
            <!--  Warning  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center" Classes="Warning"
                      Content="Warning"
                      Theme="{DynamicResource SolidButton}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource WarningBackgroundOutline}"
                      BorderBrush="{DynamicResource WarningBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource WarningForegroundOutline}" />
            </StackPanel>
            <!--  Danger  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" Spacing="5">
              <Button Width="100" HorizontalContentAlignment="Center" Classes="Danger"
                      Content="Danger"
                      Theme="{DynamicResource SolidButton}" />
              <Button Width="100" HorizontalContentAlignment="Center"
                      Background="{DynamicResource DangerBackgroundOutline}"
                      BorderBrush="{DynamicResource DangerBorderBrushOutline}"
                      BorderThickness="{StaticResource BorderThickness_1}"
                      Content="Outline"
                      CornerRadius="{StaticResource CornerRadius_6}"
                      Foreground="{DynamicResource DangerForegroundOutline}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </TabItem>

      <TabItem MinWidth="100" Header="GroupBox">
        <StackPanel Width="400" Margin="10" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Orientation="Vertical" Spacing="10">
          <u:UrsaGroupBox Margin="10"
                          Background="{DynamicResource SemiColorPrimaryLight}"
                          BorderBrush="{DynamicResource SemiColorPrimary}"
                          BorderThickness="1.5"
                          CornerRadius="{DynamicResource RadiusCardCornerRadius}"
                          HeaderSpacing="10">
            <u:UrsaGroupBox.Header>
              <TextBlock FontWeight="Bold" Text="默认 Header 位置" />
            </u:UrsaGroupBox.Header>
            <StackPanel Spacing="5">
              <DockPanel>
                <ToggleSwitch HorizontalAlignment="Left"
                              Background="{DynamicResource SemiColorPrimary}"
                              DockPanel.Dock="Right" IsChecked="True"
                              Theme="{StaticResource SimpleToggleSwitch}" />
                <TextBlock VerticalAlignment="Center" Text="显示查看新闻按钮" TextWrapping="Wrap" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <ToggleSwitch HorizontalAlignment="Left"
                              Background="{DynamicResource SemiColorPrimary}"
                              DockPanel.Dock="Right" IsChecked="False"
                              Theme="{StaticResource SimpleToggleSwitch}" />
                <TextBlock VerticalAlignment="Center" Text="显示查看通知按钮" TextWrapping="Wrap" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <ToggleSwitch HorizontalAlignment="Left"
                              Background="{DynamicResource SemiColorPrimary}"
                              DockPanel.Dock="Right" IsChecked="True"
                              Theme="{StaticResource SimpleToggleSwitch}" />
                <TextBlock VerticalAlignment="Center" Text="显示查看日志按钮" TextWrapping="Wrap" />
              </DockPanel>
            </StackPanel>
          </u:UrsaGroupBox>
          <u:UrsaGroupBox Margin="10"
                          Background="{DynamicResource SemiColorSuccessLight}"
                          BorderBrush="{DynamicResource SemiColorSuccess}"
                          BorderThickness="1.5"
                          CornerRadius="{DynamicResource RadiusCardCornerRadius}"
                          HeaderSpacing="10"
                          Theme="{DynamicResource UrsaGroupBox1}">
            <u:UrsaGroupBox.Header>
              <TextBlock FontWeight="Bold" Text="自定义 Header 位置" />
            </u:UrsaGroupBox.Header>
            <StackPanel Spacing="5">
              <DockPanel>
                <ToggleSwitch HorizontalAlignment="Left"
                              Background="{DynamicResource SemiColorPrimary}"
                              DockPanel.Dock="Right" IsChecked="True"
                              Theme="{StaticResource SimpleToggleSwitch}" />
                <TextBlock VerticalAlignment="Center" Text="显示查看新闻按钮" TextWrapping="Wrap" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <ToggleSwitch HorizontalAlignment="Left"
                              Background="{DynamicResource SemiColorPrimary}"
                              DockPanel.Dock="Right" IsChecked="False"
                              Theme="{StaticResource SimpleToggleSwitch}" />
                <TextBlock VerticalAlignment="Center" Text="显示查看通知按钮" TextWrapping="Wrap" />
              </DockPanel>
              <Separator />
              <DockPanel>
                <ToggleSwitch HorizontalAlignment="Left"
                              Background="{DynamicResource SemiColorPrimary}"
                              DockPanel.Dock="Right" IsChecked="True"
                              Theme="{StaticResource SimpleToggleSwitch}" />
                <TextBlock VerticalAlignment="Center" Text="显示查看日志按钮" TextWrapping="Wrap" />
              </DockPanel>
            </StackPanel>
          </u:UrsaGroupBox>
        </StackPanel>
      </TabItem>

      <TabItem Header="SplitView">
        <TabControl Name="TabControl_SplitView" Margin="0,0" TabStripPlacement="Left" Theme="{DynamicResource ScrollButtonTabControl}">
          <TabControl.Styles>
            <Style Selector=".Dismiss /template/ ScrollViewer#PART_ScrollViewer">
              <Setter Property="IsVisible" Value="False" />
            </Style>
          </TabControl.Styles>
          <TabControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel />
            </ItemsPanelTemplate>
          </TabControl.ItemsPanel>

          <TabItem MinWidth="100" Header="Demo1">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" RowDefinitions="Auto, *">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5">
                <Button HorizontalAlignment="Center" VerticalAlignment="Center" Click="Button_ToggleSplitView1Click" Content="打开/关闭" />
              </StackPanel>

              <SplitView Name="SplitView_Demo1" Grid.Row="1" Width="700"
                         Height="600" CompactPaneLength="50" DisplayMode="CompactOverlay"
                         IsPaneOpen="False" OpenPaneLength="300" PanePlacement="Top"
                         UseLightDismissOverlayMode="True">
                <SplitView.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#6b4c1b" />
                    <GradientStop Offset="1" Color="#291e10" />
                  </LinearGradientBrush>
                </SplitView.Background>
                <SplitView.Pane>
                  <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Margin="8,12" Orientation="Horizontal">
                      <ToggleSwitch IsChecked="{Binding #SplitView_Demo1.IsPaneOpen}" Theme="{DynamicResource IconBorderlessToggleSwitch}" />
                      <!-- <ToggleSwitch Content="{StaticResource SemiIconSidebar}" IsChecked="{Binding #SplitView_Demo1.IsPaneOpen}" Theme="{DynamicResource IconBorderlessToggleSwitch}" /> -->
                      <TextBlock Name="PaneHeader" Margin="8,0" VerticalAlignment="Center"
                                 FontWeight="Bold" Text="Playlist" />
                    </StackPanel>

                    <!-- <ListBox Grid.Row="1" ItemsSource="{Binding Songs}" /> -->
                    <ListBox Grid.Row="1" BorderBrush="{DynamicResource TabItemLinePipePointeroverBorderBrush}" BorderThickness="1">
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                      <ListBoxItem>ListBoxItem</ListBoxItem>
                    </ListBox>
                  </Grid>
                </SplitView.Pane>

                <Panel>
                  <Panel.Styles>
                    <Style Selector="Image#AlbumCover">
                      <Style.Animations>
                        <Animation IterationCount="Infinite" Duration="0:0:40">
                          <KeyFrame Cue="0%">
                            <Setter Property="RotateTransform.Angle" Value="0" />
                          </KeyFrame>
                          <KeyFrame Cue="100%">
                            <Setter Property="RotateTransform.Angle" Value="360" />
                          </KeyFrame>
                        </Animation>
                      </Style.Animations>
                    </Style>
                  </Panel.Styles>
                  <Image Name="AlbumCover" Width="200" Height="200" Source="/Assets/WORLD.png" />
                  <Arc Width="290" Height="290" StartAngle="0"
                       StrokeJoin="Round" StrokeLineCap="Round" StrokeThickness="45"
                       SweepAngle="360">
                    <Arc.Stroke>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Offset="0" Color="#010101" />
                        <GradientStop Offset="0.5" Color="#363636" />
                        <GradientStop Offset="1" Color="#010101" />
                      </LinearGradientBrush>
                    </Arc.Stroke>
                  </Arc>
                  <Arc Width="294" Height="294" StartAngle="0"
                       Stroke="Black" StrokeJoin="Round" StrokeLineCap="Round"
                       StrokeThickness="4" SweepAngle="360" />
                  <Arc Width="310" Height="310" Opacity="0.1"
                       StartAngle="0" Stroke="#C6CACD" StrokeJoin="Round"
                       StrokeLineCap="Round" StrokeThickness="10" SweepAngle="360" />
                </Panel>
              </SplitView>
            </Grid>
          </TabItem>

          <TabItem MinWidth="100" Header="Demo2">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" RowDefinitions="Auto, *">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5">
                <Button HorizontalAlignment="Center" VerticalAlignment="Center" Click="Button_ToggleSplitView2Click" Content="打开/关闭" />
              </StackPanel>

              <SplitView Name="SplitView_Demo2" Grid.Row="1" Width="700"
                         Height="600" CompactPaneLength="50" DisplayMode="CompactOverlay"
                         IsPaneOpen="False" OpenPaneLength="400" PanePlacement="Top"
                         UseLightDismissOverlayMode="False">
                <SplitView.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#6b4c1b" />
                    <GradientStop Offset="1" Color="#291e10" />
                  </LinearGradientBrush>
                </SplitView.Background>
                <SplitView.Pane>
                  <Grid Margin="0,0,0,15" RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Margin="8,12" Orientation="Horizontal">
                      <ToggleSwitch IsChecked="{Binding #SplitView_Demo2.IsPaneOpen}" Theme="{DynamicResource IconBorderlessToggleSwitch}" />
                      <!-- <ToggleSwitch Content="{StaticResource SemiIconSidebar}" IsChecked="{Binding #SplitView_Demo2.IsPaneOpen}" Theme="{DynamicResource IconBorderlessToggleSwitch}" /> -->
                      <TextBlock Name="PaneHeader2" Margin="8,0" VerticalAlignment="Center"
                                 FontWeight="Bold" Text="Playlist" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,0" HorizontalAlignment="Center" RowDefinitions="Auto,*">
                      <StackPanel Grid.Row="0">
                        <ToggleSwitch Name="collapse" OffContent="Expand" OnContent="Collapse" />
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="当前选择：" />
                          <TextBlock FontSize="15" FontWeight="Bold" Text="{Binding SelectedMenuItem.Header}" />
                        </StackPanel>
                      </StackPanel>

                      <Border Grid.Row="1" Grid.Column="0" Padding="0" Theme="{DynamicResource CardBorder}">
                        <u:NavMenu Name="menu" Classes="enable_animation" ExpandWidth="500"
                                   HeaderBinding="{Binding Header}"
                                   IconBinding="{Binding IconIndex}"
                                   IsHorizontalCollapsed="{Binding #collapse.IsChecked, Mode=OneWay}"
                                   ItemsSource="{Binding MenuItems}"
                                   SelectedItem="{Binding SelectedMenuItem}"
                                   SubMenuBinding="{Binding Children}">
                          <u:NavMenu.Styles>
                            <Style x:DataType="vm:MenuItem" Selector="u|NavMenuItem">
                              <Setter Property="IsSeparator" Value="{Binding IsSeparator}" />
                            </Style>
                          </u:NavMenu.Styles>
                          <u:NavMenu.Header>
                            <Grid HorizontalAlignment="Center" ColumnDefinitions="Auto, Auto">
                              <Panel Margin="4,10" VerticalAlignment="Center" u:NavMenu.CanToggle="True"
                                     Background="Transparent" DockPanel.Dock="Left">
                                <iri:IrihiLogo Width="32" Fill="{DynamicResource SemiGrey7}" />
                              </Panel>
                              <TextBlock Grid.Column="1" VerticalAlignment="Center" Classes="H5"
                                         IsVisible="{Binding !#menu.IsHorizontalCollapsed}"
                                         Text="Ursa Avalonia（NavMenu.Header）"
                                         Theme="{DynamicResource TitleTextBlock}" />
                            </Grid>
                          </u:NavMenu.Header>
                          <u:NavMenu.IconTemplate>
                            <DataTemplate DataType="{x:Type x:Int32}">
                              <u:TwoTonePathIcon Width="16" Height="16" Margin="5,0,0,0"
                                                 ActiveForeground="{DynamicResource SemiBlue5}"
                                                 ActiveStrokeBrush="{DynamicResource SemiBlue5}"
                                                 Data="{Binding Converter={StaticResource IconConverter}}"
                                                 Foreground="{DynamicResource SemiGrey5}"
                                                 IsActive="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=u:NavMenuItem}, Path=IsHighlighted, Mode=TwoWay}"
                                                 StrokeBrush="{DynamicResource SemiGrey5}" />
                            </DataTemplate>
                          </u:NavMenu.IconTemplate>
                        </u:NavMenu>
                      </Border>
                    </Grid>
                  </Grid>
                </SplitView.Pane>

                <Panel>
                  <Panel.Styles>
                    <Style Selector="Image#AlbumCover2">
                      <Style.Animations>
                        <Animation IterationCount="Infinite" Duration="0:0:40">
                          <KeyFrame Cue="0%">
                            <Setter Property="RotateTransform.Angle" Value="0" />
                          </KeyFrame>
                          <KeyFrame Cue="100%">
                            <Setter Property="RotateTransform.Angle" Value="360" />
                          </KeyFrame>
                        </Animation>
                      </Style.Animations>
                    </Style>
                  </Panel.Styles>
                  <Image Name="AlbumCover2" Width="200" Height="200" Source="/Assets/WORLD.png" />
                  <Arc Width="290" Height="290" StartAngle="0"
                       StrokeJoin="Round" StrokeLineCap="Round" StrokeThickness="45"
                       SweepAngle="360">
                    <Arc.Stroke>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Offset="0" Color="#010101" />
                        <GradientStop Offset="0.5" Color="#363636" />
                        <GradientStop Offset="1" Color="#010101" />
                      </LinearGradientBrush>
                    </Arc.Stroke>
                  </Arc>
                  <Arc Width="294" Height="294" StartAngle="0"
                       Stroke="Black" StrokeJoin="Round" StrokeLineCap="Round"
                       StrokeThickness="4" SweepAngle="360" />
                  <Arc Width="310" Height="310" Opacity="0.1"
                       StartAngle="0" Stroke="#C6CACD" StrokeJoin="Round"
                       StrokeLineCap="Round" StrokeThickness="10" SweepAngle="360" />
                </Panel>
              </SplitView>
            </Grid>
          </TabItem>
        </TabControl>
      </TabItem>

      <TabItem Header="ToggleSwitch">
        <StackPanel Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Vertical" Spacing="20">
          <StackPanel Background="{DynamicResource SemiBackground0Color}" Orientation="Horizontal" Spacing="5">
            <u:UrsaGroupBox Margin="10"
                            Background="{DynamicResource SemiColorPrimaryLight}"
                            BorderBrush="{DynamicResource SemiColorPrimary}"
                            BorderThickness="1.5"
                            CornerRadius="{DynamicResource RadiusCardCornerRadius}"
                            HeaderSpacing="10">
              <u:UrsaGroupBox.Header>
                <TextBlock FontWeight="Bold" Text="DefaultToggleSwitch" />
              </u:UrsaGroupBox.Header>
              <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Small" />
                  <ToggleSwitch Classes="Small" />
                  <ToggleSwitch Classes="Small" IsChecked="True" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Default" />
                  <ToggleSwitch />
                  <ToggleSwitch IsChecked="True" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Large" />
                  <ToggleSwitch Classes="Large" />
                  <ToggleSwitch Classes="Large" IsChecked="True" />
                </StackPanel>
              </StackPanel>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Margin="10"
                            Background="{DynamicResource SemiColorSuccessLight}"
                            BorderBrush="{DynamicResource SemiColorSuccess}"
                            BorderThickness="1.5"
                            CornerRadius="{DynamicResource RadiusCardCornerRadius}"
                            HeaderSpacing="10">
              <u:UrsaGroupBox.Header>
                <TextBlock FontWeight="Bold" Text="SimpleToggleSwitch" />
              </u:UrsaGroupBox.Header>
              <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Small" />
                  <ToggleSwitch Classes="Small" OffContent="否" OnContent="是" Theme="{DynamicResource SimpleToggleSwitch}" />
                  <ToggleSwitch Classes="Small" IsChecked="True" OffContent="否"
                                OnContent="是"
                                Theme="{DynamicResource SimpleToggleSwitch}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Default" />
                  <ToggleSwitch OffContent="否" OnContent="是" Theme="{DynamicResource SimpleToggleSwitch}" />
                  <ToggleSwitch IsChecked="True" OffContent="否" OnContent="是" Theme="{DynamicResource SimpleToggleSwitch}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Large" />
                  <ToggleSwitch Classes="Large" OffContent="否" OnContent="是" Theme="{DynamicResource SimpleToggleSwitch}" />
                  <ToggleSwitch Classes="Large" IsChecked="True" OffContent="否"
                                OnContent="是"
                                Theme="{DynamicResource SimpleToggleSwitch}" />
                </StackPanel>
              </StackPanel>
            </u:UrsaGroupBox>

            <u:UrsaGroupBox Margin="10"
                            Background="{DynamicResource SemiColorWarningLight}"
                            BorderBrush="{DynamicResource SemiColorWarning}"
                            BorderThickness="1.5"
                            CornerRadius="{DynamicResource RadiusCardCornerRadius}"
                            HeaderSpacing="10">
              <u:UrsaGroupBox.Header>
                <TextBlock FontWeight="Bold" Text="ButtonToggleSwitch" />
              </u:UrsaGroupBox.Header>
              <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal">
                  <ToggleSwitch Width="{StaticResource SemiSpacingExtraLoose}"
                                Height="{StaticResource SemiSpacingExtraLoose}"
                                Padding="{StaticResource SemiThicknessTight}"
                                HorizontalAlignment="Left"
                                Foreground="{DynamicResource ButtonDefaultTertiaryForeground}"
                                Theme="{DynamicResource ButtonToggleSwitch}">
                    <ToggleSwitch.Content>
                      <PathIcon Data="{StaticResource SemiIconSidebar}" Theme="{DynamicResource InnerPathIcon}" />
                    </ToggleSwitch.Content>
                  </ToggleSwitch>
                  <ToggleSwitch Width="{StaticResource SemiSpacingExtraLoose}"
                                Height="{StaticResource SemiSpacingExtraLoose}"
                                Padding="{StaticResource SemiThicknessTight}"
                                HorizontalAlignment="Left"
                                Foreground="{DynamicResource ButtonDefaultTertiaryForeground}"
                                Theme="{DynamicResource ButtonToggleSwitch}">
                    <ToggleSwitch.OnContent>
                      <PathIcon Data="{StaticResource SemiIconSun}" Theme="{DynamicResource InnerPathIcon}" />
                    </ToggleSwitch.OnContent>
                    <ToggleSwitch.OffContent>
                      <PathIcon Data="{StaticResource SemiIconMoon}" Theme="{DynamicResource InnerPathIcon}" />
                    </ToggleSwitch.OffContent>
                  </ToggleSwitch>
                </StackPanel>
              </StackPanel>
            </u:UrsaGroupBox>
          </StackPanel>
        </StackPanel>
      </TabItem>

    </TabControl>
  </Grid>
</UserControl>