<UserControl x:Class="AvaloniaApplication1.Views.TitleBarRightContent"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="using:AvaloniaApplication1.ViewModels"
             d:DesignHeight="132"
             d:DesignWidth="1000"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>
  <StackPanel Margin="0,0,5,0" HorizontalAlignment="Right" Orientation="Horizontal">
    <!--  View Logs （移到了 Footer 中）  -->
    <!-- <u:Badge Margin="0,10,8,0" Classes="Primary" CornerPosition="TopRight" Dot="True"> -->
    <!--  <u:IconButton Margin="0,-10,-8,0" VerticalAlignment="Stretch" Classes="Tertiary"  -->
    <!--  Icon="{DynamicResource SemiIconFile}"  -->
    <!--  Theme="{StaticResource BorderlessIconButton}"  -->
    <!--  ToolTip.Tip="查看日志">  -->
    <!--     <TextBlock Margin="-5,0,0,0" VerticalAlignment="Center" Text="查看日志" /> -->
    <!--   </u:IconButton> -->
    <!-- </u:Badge> -->

    <!--  View News  -->
    <u:IconButton VerticalAlignment="Stretch" Classes="Tertiary"
                  Icon="{DynamicResource SemiIconHorn}"
                  IsVisible="{Binding AppSettings.DisplayViewNewsButton}"
                  Theme="{StaticResource BorderlessIconButton}"
                  ToolTip.Tip="查看来自 Steam 的新闻">
      <u:Badge Margin="-6,0,0,0" Header="100" IsVisible="True" OverflowCount="10" />
    </u:IconButton>

    <!--  View Notifications  -->
    <u:IconButton VerticalAlignment="Stretch" Classes="Tertiary"
                  Icon="{DynamicResource SemiIconBell}"
                  IsVisible="{Binding AppSettings.DisplayViewNotificationsButton}"
                  Theme="{StaticResource BorderlessIconButton}"
                  ToolTip.Tip="查看通知">
      <!-- <u:IconButton.Icon> -->
      <!--   <PathIcon Width="12" Margin="0,0,0,0" Data="{DynamicResource SemiIconBell}" /> -->
      <!-- </u:IconButton.Icon> -->
      <u:Badge Margin="-6,0,0,0" Header="100" IsVisible="True" OverflowCount="99" />
      <!-- Badge 参考示例：
        <u:Badge Header="5" />
        <u:Badge Classes="Light" Header="NEW" />
        <u:Badge Classes="Danger" Header="99" OverflowCount="10" />
        <u:Badge Classes="Primary" Dot="True" />
        <u:Badge Classes="Secondary" Dot="True" />
        <u:Badge Classes="Tertiary" Dot="True" />
        <u:Badge Classes="Success" Dot="True" />
        <u:Badge Classes="Warning" Dot="True" />
        <u:Badge Classes="Danger" Dot="True" />
      -->
      <Button.Flyout>
        <Flyout Placement="BottomEdgeAlignedRight">
          <Flyout.ContentTemplate>
            <DataTemplate>
              <DockPanel MaxHeight="350">
                <DockPanel MinWidth="300" Margin="0,0,0,5" DockPanel.Dock="Top" LastChildFill="False">
                  <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left"
                             FontSize="15" FontWeight="Bold" Text="通知" />
                  <Button Content="查看全部" DockPanel.Dock="Right" />
                </DockPanel>
                <ScrollViewer>
                  <StackPanel>
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                    <u:IconButton Margin="0,3,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                  Content="1 条新好友请求"
                                  Icon="{DynamicResource SemiIconUserAdd}" />
                  </StackPanel>
                </ScrollViewer>
              </DockPanel>
            </DataTemplate>
          </Flyout.ContentTemplate>
        </Flyout>
      </Button.Flyout>
    </u:IconButton>

    <Menu>
      <!--  User 1  -->
      <MenuItem Padding="10,0" ToolTip.Tip="管理账户">
        <MenuItem.HeaderTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <Image Height="26" Margin="0,0,5,0" Source="/Assets/avatar.jpg" />
              <TextBlock VerticalAlignment="Center" Text="你好我是畅想" />
            </StackPanel>
          </DataTemplate>
        </MenuItem.HeaderTemplate>
        <MenuItem Header="个人中心">
          <MenuItem.Icon>
            <PathIcon Data="{StaticResource SemiIconUser}" />
          </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Header="退出登录">
          <MenuItem.Icon>
            <PathIcon Data="{StaticResource SemiIconExit}" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
      <!--  User 2  -->
      <MenuItem Padding="10,0" ToolTip.Tip="管理账户">
        <MenuItem.HeaderTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <Image Height="26" Margin="0,0,5,0" Source="/Assets/avatar.jpg" />
              <TextBlock VerticalAlignment="Center" Text="你好我是畅想" />
            </StackPanel>
          </DataTemplate>
        </MenuItem.HeaderTemplate>
        <MenuItem Header="个人中心">
          <MenuItem.Icon>
            <PathIcon Data="{StaticResource SemiIconUser}" />
          </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Header="退出登录">
          <MenuItem.Icon>
            <PathIcon Data="{StaticResource SemiIconExit}" />
          </MenuItem.Icon>
        </MenuItem>
      </MenuItem>
    </Menu>

    <!--  <u:IconButton Classes="Tertiary" Click="OpenRepository"  -->
    <!--  Icon="{DynamicResource SemiIconSetting}"  -->
    <!--  Theme="{StaticResource BorderlessIconButton}"  -->
    <!--  ToolTip.Tip="系统设置" />  -->

    <!--  主题切换  -->
    <u:ThemeToggleButton IsThreeState="True" Mode="Controller" />
  </StackPanel>
</UserControl>