<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:semi="https://irihi.tech/semi"
        x:ClassModifier="internal">

  <Design.PreviewWith>
    <Border Padding="20">
      <!--  Add Controls for Previewer Here  -->
    </Border>
  </Design.PreviewWith>

  <!--  Add Styles Here  -->
  <Styles.Resources>
    <ResourceDictionary>
      <!--  Semi使用参考链接：https://docs.irihi.tech/semi/docs/basic/resource-customization  -->
      <!--  覆写动态资源：可以在App.axaml中重新为这个资源赋值，通过覆写动态资源来基于 Semi Avalonia 的样式进行微调  -->
      <!-- <CornerRadius x:Key="ButtonCornerRadius">5</CornerRadius> -->

      <Thickness x:Key="BorderThickness_1">1</Thickness>
      <CornerRadius x:Key="CornerRadius_6">6</CornerRadius>
      <FontFamily x:Key="DefaultFontFamily">/Assets/Fonts/NotoSansJP.tff</FontFamily>
      <FontFamily x:Key="Phosphor">/Assets/Fonts/Phosphor.ttf#Phosphor</FontFamily>
      <FontFamily x:Key="PhosphorFill">/Assets/Fonts/Phosphor-Fill.ttf#Phosphor-Fill</FontFamily>

      <ResourceDictionary.ThemeDictionaries>
        <ResourceInclude x:Key="Default" Source="/Controls/Themes/Light/_index.axaml" />
        <ResourceInclude x:Key="Light" Source="/Controls/Themes/Light/_index.axaml" />
        <ResourceInclude x:Key="Dark" Source="/Controls/Themes/Dark/_index.axaml" />
        <!-- <ResourceInclude x:Key="{x:Static semi:SemiTheme.Aquatic}" Source="/Controls/Themes/HighContrast/_index.axaml" /> -->
        <!-- <ResourceInclude x:Key="{x:Static semi:SemiTheme.Desert}" Source="/Controls/Themes/HighContrast/_index.axaml" /> -->
        <!-- <ResourceInclude x:Key="{x:Static semi:SemiTheme.Dusk}" Source="/Controls/Themes/HighContrast/_index.axaml" /> -->
        <!-- <ResourceInclude x:Key="{x:Static semi:SemiTheme.NightSky}" Source="/Controls/Themes/HighContrast/_index.axaml" /> -->
      </ResourceDictionary.ThemeDictionaries>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Controls/Styles/_index.axaml" />
        <ResourceInclude Source="/Controls/Themes/Shared/_index.axaml" />
        <ResourceInclude Source="/Controls/Tokens/_index.axaml" />
        <ResourceInclude Source="/Controls/Styles/Brushes.axaml" />
        <!-- <ResourceInclude Source="/Locale/zh-cn.axaml" /> -->
        <semi:Icons />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>