<UserControl x:Class="BatchProcess3.Views.MainView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ava="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:data="clr-namespace:BatchProcess3.Data"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:view="clr-namespace:BatchProcess3.Views"
             xmlns:vm="clr-namespace:BatchProcess3.ViewModels"
             MinWidth="1400"
             MinHeight="800"
             d:DesignHeight="800"
             d:DesignWidth="1400"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid Background="{DynamicResource PrimaryBackground}" ColumnDefinitions="Auto,*">
    <Border Width="{Binding SomeWidth}" Padding="10" Background="{DynamicResource PrimaryBackgroundGradient}">
      <Grid RowDefinitions="*, Auto">
        <StackPanel Spacing="10">
          <Image Width="220" IsVisible="False" PointerPressed="Image_PointerPressed" Source="{Binding SideMenuImage}" />
          <Image Width="220" IsVisible="{Binding SideMenuExpanded}" PointerPressed="Image_PointerPressed"
                 Source="{SvgImage /Assets/Images/logo.svg}" />
          <Image Width="40" IsVisible="{Binding !SideMenuExpanded}" PointerPressed="Image_PointerPressed"
                 Source="{SvgImage /Assets/Images/icon.svg}" />

          <IconButton HorizontalAlignment="Stretch" ava:ToolTip.Tip="Home" Classes="subtle"
                      Classes.active="{Binding HomePageIsActive}"
                      Command="{Binding GoToPageCommand}"
                      CommandParameter="{x:Static data:ApplicationPageName.Home}"
                      IconText="&#xe2c2;">
            <!--  CommandParameter="HomePage"  -->
            <Label Content="Home" IsVisible="{Binding SideMenuExpanded}" />
          </IconButton>

          <IconButton HorizontalAlignment="Stretch" ava:ToolTip.Tip="Process" Classes="subtle"
                      Classes.active="{Binding ProcessPageIsActive}"
                      Command="{Binding GoToPageCommand}"
                      CommandParameter="{x:Static data:ApplicationPageName.Process}"
                      IconText="&#xe346;">
            <!--  CommandParameter="ProcessPage"  -->
            <Label Content="Process" IsVisible="{Binding SideMenuExpanded}" />
          </IconButton>

          <IconButton HorizontalAlignment="Stretch" ava:ToolTip.Tip="Actions" Classes="subtle"
                      Classes.active="{Binding ActionsPageIsActive}"
                      Command="{Binding GoToPageCommand}"
                      CommandParameter="{x:Static data:ApplicationPageName.Actions}"
                      IconText="&#xe7f2;">
            <!--  CommandParameter="ActionsPage"  -->
            <Label Content="Actions" IsVisible="{Binding SideMenuExpanded}" />
          </IconButton>

          <IconButton HorizontalAlignment="Stretch" ava:ToolTip.Tip="Macros" Classes="subtle"
                      Classes.active="{Binding MacrosPageIsActive}"
                      Command="{Binding GoToPageCommand}"
                      CommandParameter="{x:Static data:ApplicationPageName.Macros}"
                      IconText="&#xe3ee;">
            <!--  CommandParameter="MacrosPage"  -->
            <Label Content="Macros" IsVisible="{Binding SideMenuExpanded}" />
          </IconButton>

          <IconButton HorizontalAlignment="Stretch" ava:ToolTip.Tip="Reporter" Classes="subtle"
                      Classes.active="{Binding ReporterPageIsActive}"
                      Command="{Binding GoToPageCommand}"
                      CommandParameter="{x:Static data:ApplicationPageName.Reporter}"
                      IconText="&#xeb7a;">
            <!--  CommandParameter="ReporterPage"  -->
            <Label Content="Reporter" IsVisible="{Binding SideMenuExpanded}" />
          </IconButton>

          <IconButton HorizontalAlignment="Stretch" ava:ToolTip.Tip="History" Classes="subtle"
                      Classes.active="{Binding HistoryPageIsActive}"
                      Command="{Binding GoToPageCommand}"
                      CommandParameter="{x:Static data:ApplicationPageName.History}"
                      IconText="&#xe03a;">
            <!--  CommandParameter="HistoryPage"  -->
            <Label Content="History" IsVisible="{Binding SideMenuExpanded}" />
          </IconButton>
        </StackPanel>

        <Button Grid.Row="1" ava:ToolTip.Tip="Settings" Classes="transparent subtle"
                Classes.active="{Binding SettingsPageIsActive}"
                Command="{Binding GoToPageCommand}"
                CommandParameter="{x:Static data:ApplicationPageName.Settings}">
          <!--  CommandParameter="SettingsPage"  -->
          <Label Classes="icon-only" Content="&#xe272;" />
        </Button>
      </Grid>
    </Border>

    <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Foreground="White" />

  </Grid>
</UserControl>